rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    function isAuth() {
      return request.auth != null;
    }

    // General rule: authenticated users can read and write all files
    match /{allPaths=**} {
      allow read, write: if isAuth();
    }

    // AI help system — explicit rules for help_conversations and knowledge base
    match /help_conversations/{file} {
      allow read, write, list: if isAuth();
    }

    match /system/{file} {
      allow read, list: if isAuth();
      allow write: if isAuth();
    }
  }
}
