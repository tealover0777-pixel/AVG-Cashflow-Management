rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function getRole() {
      return request.auth.token.role;
    }

    function getTenant() {
      return request.auth.token.tenantId;
    }

    function isRole(role) {
      return isSignedIn() && getRole() == role;
    }

    function hasPermission(perm) {
      return isSignedIn() && 
             get(/databases/$(database)/documents/role_types/$(getRole())).data.permissions.hasAny([perm]);
    }

    function isTenantMember(tenantId) {
      return isSignedIn() && getTenant() == tenantId;
    }

    // --- Role-based access check functions ---
    function isSecretAdmin() {
      return isRole('R10010') || (isSignedIn() && 'email' in request.auth.token && request.auth.token.email.lower() == 'kyuahn@yahoo.com');
    }

    function isCompanySuperAdmin() {
      return isRole('R10009') || isRole('R10010') ||
             isRole('Platform Admin') || isRole('Super Admin') ||
             isRole('L2 Admin') || isRole('company_super_admin_read_write');
    }

    function isCompanySupport() {
        return isRole('R10006');
    }

    // Global role: IsGlobal flag set in custom claims by inviteUser
    function isGlobalRole() {
        return isSignedIn() && request.auth.token.isGlobal == true;
    }

    function isTenantAdmin(tenantId) {
        return isTenantMember(tenantId) && (
            getRole() == 'R10004' ||
            getRole() == 'R10005' ||
            getRole() == 'Tenant Admin' ||
            getRole() == 'Admin' ||
            getRole() == 'Tenant Owner' ||
            getRole() == 'tenant_admin_super_user' ||
            getRole() == 'tenant_admin_read_write'
        );
    }

    function isTenantAdminRead(tenantId) {
        return isTenantMember(tenantId) && (
            getRole() == 'Tenant Owner' ||
            getRole() == 'Tenant Admin' ||
            getRole() == 'Tenant Manager' ||
            getRole() == 'tenant_admin_super_user' ||
            getRole() == 'tenant_admin_read_write' ||
            getRole() == 'tenant_admin_read_only'
        );
    }


    // --- Rules ---

    // Allow signed in users to see the list of tenants (necessary for tenant selector)
    match /tenants/{tenantId} {
      allow read: if isSignedIn();
    }

    // Secret admin has global read/write access.
    match /{path=**} {
      allow read, write: if isSecretAdmin();
    }

    // Global roles (IsGlobal) have read/write access to everything
    match /{path=**} {
      allow read, write: if isGlobalRole();
    }

    // Global user-role mappings
    match /global_users/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.auth.uid == docId
         && request.resource.data.keys().hasAll(['email'])
         && request.resource.data.keys().hasOnly(['email', 'first_name', 'last_name', 'user_name', 'phone', 'photo_url', 'role', 'tenantId', 'status', 'last_login', 'last_updated', 'updated_at', 'isGlobal']);
      allow update: if request.auth != null && request.auth.uid == docId
         && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['first_name', 'last_name', 'user_name', 'phone', 'photo_url', 'status', 'last_login', 'last_updated', 'updated_at']);
      allow write: if isSecretAdmin() || isGlobalRole() || isCompanySuperAdmin() || isTenantAdmin(request.auth.token.tenantId);
    }

    // Global role definitions (role_types)
    match /role_types/{roleId} {
      allow read: if request.auth != null;
      allow write: if isSecretAdmin() || isGlobalRole() || isCompanySuperAdmin() || isTenantAdmin(request.auth.token.tenantId);
    }

    // Global dimensions mapping
    match /dimensions/{dimensionId} {
      allow read: if request.auth != null;
      allow write: if isGlobalRole() || isCompanySuperAdmin() || isTenantAdmin(request.auth.token.tenantId);
    }

    // === AI Assistant / Help System Rules ===
    match /system/{docId} {
      allow read: if request.auth != null;
      allow write: if isCompanySuperAdmin() || isGlobalRole();
    }

    match /ai_conversations/{docId} {
      allow create: if request.auth != null;
      allow read, update: if request.auth != null &&
        (request.auth.uid == resource.data.user_id || isCompanySuperAdmin() || isGlobalRole());
      allow delete: if isCompanySuperAdmin() || isGlobalRole();
    }

    // Rules for data within a tenant.
    match /tenants/{tenantId}/{document=**} {
      allow read, write: if isCompanySuperAdmin() || isSecretAdmin() || isGlobalRole();
      allow read: if isCompanySupport() || isTenantMember(tenantId);
      allow write: if isTenantAdmin(tenantId);
    }

    // Rules for specific collections for a tenant_user.
    match /tenants/{tenantId}/users/{userId} {
        allow read: if isTenantMember(tenantId) && (request.auth.uid == userId || resource.data.auth_uid == request.auth.uid || hasPermission('USER_VIEW') || hasPermission('USER_PROFILE_VIEW'));
        allow create: if isTenantMember(tenantId) && hasPermission('USER_CREATE');
        allow update: if isTenantMember(tenantId) && (resource.data.auth_uid == request.auth.uid || hasPermission('USER_UPDATE') || hasPermission('USER_PROFILE_UPDATE'))
           && (resource.data.auth_uid != request.auth.uid ? true : request.resource.data.diff(resource.data).affectedKeys().hasOnly(['first_name', 'last_name', 'user_name', 'phone', 'photo_url', 'status', 'last_login', 'last_updated', 'updated_at']));
        allow delete: if isTenantMember(tenantId) && (hasPermission('USER_DELETE') || hasPermission('USER_PROFILE_DELETE'));
    }

    match /tenants/{tenantId}/deals/{docId} {
        allow read: if isTenantMember(tenantId) && hasPermission('DEAL_VIEW');
        allow create: if isTenantMember(tenantId) && hasPermission('DEAL_CREATE');
        allow update: if isTenantMember(tenantId) && hasPermission('DEAL_UPDATE');
        allow delete: if isTenantMember(tenantId) && hasPermission('DEAL_DELETE');
    }



    match /tenants/{tenantId}/paymentSchedules/{docId} {
        allow read: if isTenantMember(tenantId) && hasPermission('PAYMENT_SCHEDULE_VIEW');
        allow create: if isTenantMember(tenantId) && hasPermission('PAYMENT_SCHEDULE_CREATE');
        allow update: if isTenantMember(tenantId) && hasPermission('PAYMENT_SCHEDULE_UPDATE');
        allow delete: if isTenantMember(tenantId) && hasPermission('PAYMENT_SCHEDULE_DELETE');
    }

    match /tenants/{tenantId}/contacts/{docId} {
        allow read: if isTenantMember(tenantId) && hasPermission('CONTACT_VIEW');
        allow create: if isTenantMember(tenantId) && hasPermission('CONTACT_CREATE');
        allow update: if isTenantMember(tenantId) && hasPermission('CONTACT_UPDATE');
        allow delete: if isTenantMember(tenantId) && hasPermission('CONTACT_DELETE');
    }

    match /tenants/{tenantId}/fees/{docId} {
        allow read: if isTenantMember(tenantId) && hasPermission('FEE_VIEW');
        allow create: if isTenantMember(tenantId) && hasPermission('FEE_CREATE');
        allow update: if isTenantMember(tenantId) && hasPermission('FEE_UPDATE');
        allow delete: if isTenantMember(tenantId) && hasPermission('FEE_DELETE');
    }

    match /tenants/{tenantId}/payments/{docId} {
        allow read: if isTenantMember(tenantId) && hasPermission('PAYMENT_VIEW');
        allow create: if isTenantMember(tenantId) && hasPermission('PAYMENT_CREATE');
        allow update: if isTenantMember(tenantId) && hasPermission('PAYMENT_UPDATE');
        allow delete: if isTenantMember(tenantId) && hasPermission('PAYMENT_DELETE');
    }

    match /tenants/{tenantId}/investments/{docId} {
        allow read: if isTenantMember(tenantId) && hasPermission('INVESTMENT_VIEW');
        allow create: if isTenantMember(tenantId) && hasPermission('INVESTMENT_CREATE');
        allow update: if isTenantMember(tenantId) && hasPermission('INVESTMENT_UPDATE');
        allow delete: if isTenantMember(tenantId) && hasPermission('INVESTMENT_DELETE');
    }

    match /tenants/{tenantId}/reports/{docId} {
        allow read: if isTenantMember(tenantId) && hasPermission('REPORT_VIEW');
        allow create, update, delete: if isTenantMember(tenantId) && (hasPermission('REPORT_CREATE') || hasPermission('REPORT_UPDATE') || hasPermission('REPORT_DELETE'));
    }

    match /tenants/{tenantId}/ledger/{docId} {
        allow read: if isTenantMember(tenantId) && hasPermission('PAYMENT_VIEW');
        allow create, update, delete: if isTenantMember(tenantId) && hasPermission('PAYMENT_CREATE');
    }

    match /tenants/{tenantId}/achBatches/{docId} {
        allow read: if isTenantMember(tenantId) && hasPermission('PAYMENT_VIEW');
        allow create, update, delete: if isTenantMember(tenantId) && hasPermission('PAYMENT_CREATE');
    }
  }
}
